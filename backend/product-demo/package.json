{
  "name": "flowforge-product-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Sample child toys catalog API (Express + MongoDB + Mongoose + TypeScript)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["express", "mongodb", "mongoose", "typescript", "demo"],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.8.3",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.1",
    "nodemon": "^3.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
